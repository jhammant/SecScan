# GitHub API token (required for private repos, recommended for rate limits)
GITHUB_TOKEN=

# LMStudio server (default matches `lms server start`)
LMSTUDIO_HOST=localhost:1234

# Default model identifier (override per-run with --model)
SECSCAN_MODEL=

# Where cloned repos and scan artifacts are written
SECSCAN_WORKDIR=./.secscan

# Exploit sandbox: require explicit opt-in before running PoCs
SECSCAN_EXPLOIT_CONFIRM=true
